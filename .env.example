# ============================================================================
# Production LMS — environment configuration
# Copy to .env and adjust. For Docker, docker-compose already supplies the
# key values; this file is for running the API directly (non-Docker).
# ============================================================================

APP_NAME="Production LMS"
APP_ENV=local
# A real key is pre-filled so the app boots out of the box. Generate your own
# for any real deployment:  php artisan key:generate
APP_KEY=base64:SsyuL5jtBD1AjhvZlZEcdMuX3fMFwfLit5uKlWPNMfs=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ── Database ──
# Connect as the NON-OWNER lms_app role so row-level security is enforced.
# Docker: set DB_HOST=postgres. Running directly: 127.0.0.1.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lms_full
DB_USERNAME=lms_app
DB_PASSWORD=lms_app_password

# ── Auth (JWT) ──
# Generate a long random string, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ── Cache / queue / sessions ──
# Direct run defaults to file/database (no Redis needed). Docker overrides these
# to redis automatically.
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
LOG_CHANNEL=stack

# ── Frontend origin (CORS + links in emails) ──
FRONTEND_URL=http://localhost:3000

# ── Mail (optional; needed for tenant welcome emails to actually send) ──
# Leave MAIL_MAILER=log to record emails to the log instead of sending.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@your-domain.com

# ── Stripe (optional; needed for card payments) ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── M-Pesa Daraja (optional; needed for live STK push) ──
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback
# Callback hardening (recommended for production)
MPESA_CALLBACK_SECRET=
MPESA_ALLOWED_IPS=196.201.214.200,196.201.214.206,196.201.214.207,196.201.214.208

# ── Video (Mux signed playback — set to issue real signed tokens) ──
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY=
