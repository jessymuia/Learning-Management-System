# ─── Frontend environment ───────────────────────────────────────────
# Copy to .env.local and adjust. Docker sets these automatically.

# URL of the Laravel API backend (no trailing slash)
# Development (running directly):
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Docker (service name):
# NEXT_PUBLIC_API_BASE=http://api:8000
# Production:
# NEXT_PUBLIC_API_BASE=https://api.your-domain.com
